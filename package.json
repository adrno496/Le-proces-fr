{
  "name": "leproces",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync": "npx cap sync android",
    "open": "npx cap open android",
    "ship": "npm run sync && cd android && JAVA_HOME=/opt/homebrew/opt/openjdk@21 ./gradlew bundleRelease",
    "icons": "npx capacitor-assets generate --android",
    "test": "node test.mjs",
    "check": "for f in www/js/*.js; do node --check \"$f\" || exit 1; done && node test.mjs",
    "serve": "npx serve www/",
    "deploy:vercel": "npx vercel --prod",
    "deploy:vercel-preview": "npx vercel"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0"
  }
}
